# Copy this file to .env on the server and fill in real values.
# Never commit .env to git.

# API authentication — all protected endpoints require X-API-Key: <value>
API_KEY=change_me_generate_with_openssl_rand_hex_32

# Flask environment
FLASK_ENV=production

# MariaDB — used by both the app container and the db container
MYSQL_ROOT_PASSWORD=change_me_generate_with_openssl_rand_hex_16
MYSQL_DATABASE=recipes_db
MYSQL_USER=recipes_user
MYSQL_PASSWORD=change_me_generate_with_openssl_rand_hex_16

# Database URL for the app (matches the values above)
# TEMPLATE: replace recipes-db with your actual db container name
DATABASE_URL=mysql+pymysql://recipes_user:change_me_generate_with_openssl_rand_hex_16@recipes-db/recipes_db

# Anthropic API key — used for Claude AI recipe import feature
# Retrieve from Vaultwarden at https://vault.mitchellnet.local/
ANTHROPIC_API_KEY=change_me_retrieve_from_vaultwarden
